{
  "name": "cost-estimator",
  "version": "0.1.0",
  "description": "Abonmarche Cost Estimator - reads quantities from AutoCAD and prices them against historical bid data via CostEstDB",
  "main": "out/main/index.js",
  "author": {
    "name": "Abonmarche Consultants"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:main": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer",
    "rebuild": "cross-env npm_config_clang=0 electron-rebuild -f -w winax",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder --win --publish never",
    "publish": "electron-vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "winax": "^3.4.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
