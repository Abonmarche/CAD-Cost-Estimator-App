# Anthropic API key for the Claude Agent SDK
# Used only for the resolution-chat phase (flagged pay items)
ANTHROPIC_API_KEY=sk-ant-...

# CostEstDB remote MCP server URL (include ?code= for Azure Function auth)
COSTESTDB_MCP_URL=https://func-costestdb-mcp.azurewebsites.net/runtime/webhooks/mcp/sse?code=YOUR_FUNCTION_KEY_HERE

# AutoCAD COM ProgID — AutoCAD 2024 is 24.3. Override if a different version is installed.
AUTOCAD_PROGID=AutoCAD.Application.24.3

# Optional auto-update feed URL (used by electron-updater at runtime)
# UPDATE_SERVER_URL=https://abonmarche-updates.example.com/cost-estimator/
